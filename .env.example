# Drizzle
# Replace with your DB credentials!
# Use postgres:// (not postgresql://) and only ?sslmode=require for Neon
DATABASE_URL="postgres://user:password@host:port/db-name?sslmode=require"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""
